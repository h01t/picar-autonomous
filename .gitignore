# ─── macOS ────────────────────────────────────────────────────────────────────
**/.DS_Store
.AppleDouble
.LSOverride

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.env
.venv/
venv/
*.egg

# ─── ML / Model artifacts ─────────────────────────────────────────────────────
# Model binaries must be regenerated via workstation/train.py + workstation/export.py
*.pt
*.pth
model_metadata.json

# ─── Dataset ──────────────────────────────────────────────────────────────────
# Raw images are too large for git — store externally or use a data versioning tool
dataset/images/
# Backup generated by workstation/clean_dataset.py
dataset/labels_original.csv

# ─── Jupyter ──────────────────────────────────────────────────────────────────
docs/.ipynb_checkpoints/
**/.ipynb_checkpoints/
*.ipynb_checkpoints

# ─── Docs exports ─────────────────────────────────────────────────────────────
# TIFF exports are too large for git (50-60 MB each). PNG at 600 DPI is sufficient.
docs/exports/tiff/
**/*.tiff
**/*.tif

# ─── Flutter / Dart ───────────────────────────────────────────────────────────
app/build/
app/.dart_tool/
app/.flutter-plugins-dependencies
app/.pub-cache/
app/.pub/
app/coverage/
app/android/local.properties
app/android/.gradle/
app/android/.kotlin/
app/android/app/debug/
app/android/app/profile/
app/android/app/release/
app/ios/Flutter/.last_build_id
app/**/*.class
app/**/*.log

# ─── Linters / formatters ─────────────────────────────────────────────────────
.ruff_cache/
.mypy_cache/
.pytest_cache/

# ─── IDEs ─────────────────────────────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.swp
*.swo
